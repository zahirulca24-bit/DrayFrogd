@@ -0,0 +1,45 @@
+from __future__ import annotations
+
+import unittest
+
+from app.execution_core import get_active_trades, get_operator_active_trades, replace_active_trades
+from app.trade_state import (
+    is_capacity_blocking_status,
+    is_exchange_active_status,
+    is_reconcilable_status,
+)
+
+
+class TradeStatusSeparationTests(unittest.TestCase):
+    def tearDown(self) -> None:
+        replace_active_trades([])
+
+    def test_pending_and_stale_rows_never_enter_operator_active_state(self) -> None:
+        replace_active_trades(
+            [
+                {"journal_id": "active", "status": "active", "order_id": "a"},
+                {"journal_id": "pending", "status": "close_pending_sync", "order_id": "b"},
+                {"journal_id": "recon", "status": "reconciliation_pending", "order_id": "c"},
+                {"journal_id": "stale", "status": "journal_stale", "order_id": "d"},
+                {"journal_id": "closed", "status": "closed", "order_id": "e"},
+            ]
+        )
+
+        tracked = get_active_trades()
+        active = get_operator_active_trades()
+        self.assertEqual([trade["journal_id"] for trade in tracked], ["active"])
+        self.assertEqual([trade["journal_id"] for trade in active], ["active"])
+
+    def test_pending_states_block_capacity_but_are_not_operator_active(self) -> None:
+        for status in ("close_pending_sync", "reconciliation_pending"):
+            self.assertTrue(is_capacity_blocking_status(status))
+            self.assertTrue(is_reconcilable_status(status))
+            self.assertFalse(is_exchange_active_status(status))
+
+        self.assertFalse(is_capacity_blocking_status("journal_stale"))
+        self.assertFalse(is_reconcilable_status("journal_stale"))
+        self.assertFalse(is_exchange_active_status("journal_stale"))
+
+
+if __name__ == "__main__":
+    unittest.main()
